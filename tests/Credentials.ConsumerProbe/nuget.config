<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    The ConsumerProbe restores the credentials-dotnet packages from a local feed populated by
    tools/check-no-newtonsoft-closure.sh (dotnet pack -> ../../artifacts/local-feed), plus nuget.org
    for the substrate dependencies. <clear/> drops the repo-root source set so this is self-contained.
  -->
  <packageSources>
    <clear />
    <add key="local-feed" value="../../artifacts/local-feed" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
